# Alpaca API credentials
# Get these from: https://app.alpaca.markets → Paper Trading → API Keys
# Or for live: https://app.alpaca.markets → Live Trading → API Keys
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=1000

# Trade limits — these are your guardrails
MAX_TRADE_SIZE_USD=100        # No single trade can exceed this value
MAX_TRADES_PER_DAY=3          # Bot stops executing after this many trades in a calendar day

# Symbol and timeframe
# Crypto: BTC/USD, ETH/USD, etc.
# Stocks: AAPL, SPY, TSLA, etc.
SYMBOL=BTC/USD
TIMEFRAME=4H

# Set to "true" to run in paper trading mode (uses Alpaca's paper trading API)
PAPER_TRADING=true
